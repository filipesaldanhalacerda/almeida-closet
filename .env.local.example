# ==========================================================================
# Almeida Closet — variáveis de ambiente
# Copie este arquivo para ".env.local" e preencha com os dados do seu projeto
# Supabase (veja o README.md, passo a passo).
# ==========================================================================

# URL do projeto Supabase (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave pública "anon" (Project Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Chave "service_role" — SECRETA, só usada no servidor (API routes e seed).
# NUNCA exponha esta chave no front-end. (Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Sufixo dos e-mails sintéticos internos usados pela autenticação por usuário.
# Não precisa ser um domínio real; serve apenas para o Supabase Auth.
AUTH_EMAIL_DOMAIN=almeidacloset.local

# Dados do primeiro gestor criado pelo script de seed (npm run seed)
SEED_GESTOR_NOME=Rafael Almeida
SEED_GESTOR_USUARIO=rafael
SEED_GESTOR_SENHA=almeida123
